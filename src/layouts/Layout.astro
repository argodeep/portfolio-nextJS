---
import Header from "@components/Header.astro";
import { Font } from "astro:assets";
import { SITE_CONFIG } from "@config";
import Footer from "@components/Footer.astro";

const {
  title,
  description,
  siteLogo,
  navLinks,
  lang,
  author,
  socialLinks,
  socialImage,
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
} = SITE_CONFIG;

const ogImgUrl = canonicalURL + socialImage;
---

<!doctype html>
<html lang={lang} class="scroll-pt-16 scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#000000" />
    <meta name="color-scheme" content="dark" />
    
    <!-- Favicon -->
    <link rel="icon" href="/arghya-small.jpg" />
    <link rel="apple-touch-icon" href="/arghya-small.jpg" />
    <link rel="shortcut icon" href="/arghya-small.jpg" />
    <link rel="manifest" href="/manifest.json" />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Title -->
    <title>{title}</title>

    <!-- Fonts -->
    <Font cssVariable="--font-gabarito" preload />
    <Font cssVariable="--font-be-vietnam-pro" preload />

    <!-- Open Graph / Social Media Tags -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Arghyadeep Majumder" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImgUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@argodeep" />
    <meta name="twitter:creator" content="@argodeep" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImgUrl} />
    <meta name="twitter:image:alt" content={title} />

    <!-- Schema.org JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "@id": canonicalURL,
      "name": "Arghyadeep Majumder",
      "jobTitle": "Senior Engineer & Solution Architect",
      "description": description,
      "image": ogImgUrl,
      "url": canonicalURL,
      "sameAs": [
        "https://x.com/argodeep",
        "https://github.com/argodeep",
        "https://linkedin.com/in/argodeep"
      ],
      "worksFor": {
        "@type": "Organization",
        "name": "Self-employed"
      },
      "knowsAbout": ["System Design", "Full-Stack Development", "Microservices", "React", "React Native", "TypeScript"]
    })} />
  </head>
  <body class="bg-black font-sans">
    <Header siteLogo={siteLogo} navLinks={navLinks} />
    <main class="mx-auto max-w-3xl px-5">
      <slot />
    </main>
    <Footer author={author} socialLinks={socialLinks} />
  </body>
</html>
