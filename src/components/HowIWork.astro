---
import Section from "./Section.astro";
import type { HowIWorkProps } from "@types";

type Props = HowIWorkProps;

const { description, skills } = Astro.props;
---

<Section text="How I work as a Senior Engineer" href="how-i-work">
  <div class="space-y-8">
    <div class="whitespace-pre-wrap text-base text-neutral leading-relaxed md:text-lg">
      {description}
    </div>
    <div class="grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-4">
      {
        skills.map((skill) => (
          <div class="rounded-lg border border-neutral/20 bg-neutral/5 px-4 py-3 text-center text-sm font-medium text-neutral hover:bg-neutral/10 transition-colors">
            {skill}
          </div>
        ))
      }
    </div>
  </div>
</Section>
