---
import Section from "./Section.astro";
import type { RecognitionProps } from "@types";

interface Props {
  recognitions: RecognitionProps[];
}

const { recognitions } = Astro.props;
---

<Section text="A Few Recognitions" href="recognitions">
  <div class="space-y-8">
    {
      recognitions.map(({ title, description, company, link }) => (
        <div class="border-l-2 border-primary pl-6">
          <h3 class="mb-2 font-serif text-xl font-semibold text-white">
            {title}
          </h3>
          <p class="mb-2 text-sm text-primary font-medium">{company}</p>
          <p class="text-base text-neutral leading-relaxed">
            {description}
            {link && (
              <>
                {" "}
                <a
                  href={link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-primary hover:underline"
                >
                  Details
                </a>
              </>
            )}
          </p>
        </div>
      ))
    }
  </div>
</Section>
