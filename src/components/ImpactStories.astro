---
import Section from "./Section.astro";
import type { ImpactStoryProps } from "@types";

interface Props {
  stories: ImpactStoryProps[];
}

const { stories } = Astro.props;
---

<Section text="Impact Stories" href="impact">
  <div class="space-y-8">
    {
      stories.map(({ number, description }) => (
        <div class="flex gap-6 md:gap-8">
          <div class="flex-shrink-0">
            <span class="text-3xl font-bold text-primary md:text-4xl">{number}</span>
          </div>
          <div class="flex-1">
            <p class="text-base text-neutral leading-relaxed md:text-lg">{description}</p>
          </div>
        </div>
      ))
    }
  </div>
</Section>
